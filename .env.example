# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: postgresql+asyncpg://nordavix:nordavix_dev@localhost:5432/nordavix
# Production: postgresql+asyncpg://<user>:<pass>@<supabase-pooler-host>:5432/postgres
DATABASE_URL=postgresql+asyncpg://nordavix:nordavix_dev@localhost:5432/nordavix

# ── Redis (Celery broker + result backend) ────────────────────────────────────
# Local dev: redis://localhost:6379/0
# Production (Upstash): rediss://:password@<upstash-host>:6380  (TLS, note rediss://)
REDIS_URL=redis://localhost:6379/0

# ── Clerk (Authentication) ────────────────────────────────────────────────────
# Dashboard → API Keys. Clerk manages JWTs; we verify signatures against their JWKS.
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
# Dashboard → API Keys → Advanced → JWT public key endpoint
CLERK_JWKS_URL=https://<your-clerk-domain>.clerk.accounts.dev/.well-known/jwks.json

# ── Cloudflare R2 (File Storage) ──────────────────────────────────────────────
# Dashboard → R2 → Manage R2 API Tokens. Client data is stored under tenant-isolated
# prefixes: {tenant_id}/{resource_type}/{filename}. Encryption at rest is R2-default.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nordavix-files
# Public or private URL base — used to generate signed download URLs
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Model is pinned in config so upgrades are a one-line change
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true

# ── Sentry ────────────────────────────────────────────────────────────────────
# Leave blank to disable locally. Never log client data — Sentry config in main.py
# strips PII from breadcrumbs and request bodies.
SENTRY_DSN=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Vite dev server default shown.
CORS_ORIGINS=http://localhost:5173

# ── Frontend (.env.local in /frontend — copy these three lines) ───────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
VITE_API_BASE_URL=http://localhost:8000
