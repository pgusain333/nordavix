FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# Build context is the project root (same as Dockerfile)
COPY backend/requirements.txt requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY backend/ .

# Run Celery worker — processes AI narrative generation tasks from Redis queue
CMD celery -A celery_app worker -l info --concurrency 2
